# Backend API URL (used by Next.js rewrites in dev, and server-side fetch in prod)
API_URL="http://localhost:4000"

# Public API URL for client-side fetches (browser)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# JWT Secret — must match backend JWT_SECRET exactly
JWT_SECRET="novavest-demo-secret-key-32chars-min"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
