# Database
DATABASE_URL="postgresql://user:password@localhost:5432/novavest?schema=public"

# JWT Secret (min 32 chars) — must match frontend JWT_SECRET
JWT_SECRET="novavest-demo-secret-key-32chars-min"

# Server
PORT=4000

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# Environment
NODE_ENV="development"
